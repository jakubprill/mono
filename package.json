{
  "name": "mono",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "bun run --filter=\"*\" --parallel --skip-if-missing lint",
    "prepare": "effect-language-service patch",
    "test": "bun run --filter=\"*\" --parallel --skip-if-missing test",
    "typecheck": "bun run --filter=\"*\" --parallel --skip-if-missing typecheck"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:tools",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "catalogs": {
    "effect": {
      "@effect/platform-bun": "4.0.0-beta.93",
      "@effect/vitest": "4.0.0-beta.93",
      "effect": "4.0.0-beta.93"
    },
    "tools": {
      "@effect/language-service": "0.86.2",
      "typescript": "6.0.3",
      "vitest": "4.1.9"
    }
  }
}
